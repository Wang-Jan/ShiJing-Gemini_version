# Copy this file to `.env` for local development.

# Required: Garden model service key and service base URL.
GARDEN_API_KEY=your_garden_api_key_here
GARDEN_API_BASE_URL=http://127.0.0.1:8000

# Required in real use: secret used to sign login session tokens.
SESSION_SECRET=replace_with_a_long_random_secret_string

# Required: MySQL connection used by the app server.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=shijing

# Optional: path to the old SQLite file when running `npm run migrate:mysql`.
SQLITE_MIGRATION_PATH=database.sqlite
